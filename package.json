{
  "name": "redux-tetris",
  "version": "2.0.0",
  "description": "Tetris with React, Redux, Ramda, and TypeScript — point-free reducer composition",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b"
  },
  "license": "MIT",
  "packageManager": "npm@11.17.0",
  "dependencies": {
    "ramda": "^0.32.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "redux": "^5.0.1"
  },
  "devDependencies": {
    "@types/ramda": "^0.31.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  }
}
